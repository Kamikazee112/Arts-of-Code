            </div>

            <div class="p-6 md:p-8 border border-red-200 bg-red-50/30 rounded-2xl" x-data="{ showConfirm: false, confirmed: '' }">
                <h3 class="font-bold text-[16px] text-red-600 mb-1">Delete Account</h3>
                <p class="text-[13.5px] text-[var(--muted)] mb-5 leading-relaxed">
                    This will permanently delete your account, your profile, all articles you wrote, and all of your progress on this platform. This action is absolutely irreversible.
                </p>

                @if(!session('account_deleted'))
                    <div x-show="showConfirm" x-transition class="mb-5 p-4 bg-white border border-red-100 rounded-xl max-w-md">
                        <label class="block text-[13px] font-semibold text-red-700 mb-2">
                            To confirm, please type <span class="font-mono bg-red-50 px-2 py-0.5 rounded text-red-600 font-bold select-all">DELETE</span> below:
                        </label>
                        <input type="text" x-model="confirmed" placeholder="Type DELETE to confirm" class="input border-red-200 focus:border-red-500 focus:shadow-red-200">
                    </div>

                    <div class="flex flex-col sm:flex-row gap-3">
                        <button
                            @click="if (!showConfirm) { showConfirm = true } else if (confirmed === 'DELETE') { $refs.deleteForm.submit() }"
                            class="btn-danger w-full sm:w-auto px-6 py-2.5" :disabled="showConfirm && confirmed !== 'DELETE'"
                            x-text="showConfirm ? 'Permanently Delete My Account' : 'Delete Account'">
                        </button>
                        
                        <button x-show="showConfirm" @click="showConfirm = false; confirmed = ''" 
                                class="btn-outline border-slate-300 text-slate-700 hover:bg-slate-50 hover:border-slate-400 w-full sm:w-auto px-6 py-2.5">
                            Cancel
                        </button>
                    </div>
                @else
                    <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-100 rounded-xl text-emerald-800 text-[14px]">
                        <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>Your account has been deleted successfully.</span>
                    </div>
                @endif

                <form x-ref="deleteForm" method="POST" action="/settings/account/delete" class="hidden">
                    @csrf
                </form>
